{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "BaseUrl": "http://localhost:8080",
    "Realm": "auth-demo",
    "AdminUsername": "admin",
    "AdminPassword": "admin",
    "PublicClientId": "public-client",
    "AuthorizationUrl": "http://localhost:8080/realms/auth-demo/protocol/openid-connect/auth",
    "TokenUrl": "http://localhost:8080/realms/auth-demo/protocol/openid-connect/token"
  },
  "Authentication": {
    "MetadataAddress": "http://localhost:8080/realms/auth-demo/.well-known/openid-configuration",
    "ValidIssuer": "http://localhost:8080/realms/auth-demo",
    "ClientId": "public-client"
  }
}
